generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id
  name         String
  email        String
  emailVerified Boolean  @default(false)
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions         Session[]
  accounts         Account[]
  workflows        Workflow[]
  dataLibraryFiles DataLibraryFile[]
  sharedNodes      SharedNode[]     @relation("CreatedSharedNodes")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String   @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id        String   @id
  identifier String
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String
  name        String
  slug        String?  @unique
  description String?

  definition  Json

  isPublic    Boolean  @default(false)
  isTemplate  Boolean  @default(false)
  tags        String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  versions         WorkflowVersion[]
  shares           WorkflowShare[]
  dataLibraryFiles DataLibraryFile[]

  @@index([userId])
  @@index([isPublic])
  @@index([isTemplate])
  @@map("workflow")
}

model WorkflowVersion {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @db.Uuid
  version    Int
  definition Json
  changeNote String?
  createdAt  DateTime @default(now())

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, version])
  @@unique([workflowId, version])
  @@map("workflow_version")
}

model WorkflowShare {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @db.Uuid
  sharedWith String?  @db.Uuid
  permission String   // "view", "use", "edit"
  createdAt  DateTime @default(now())

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([sharedWith])
  @@map("workflow_share")
}

model DataLibraryFile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String
  workflowId  String?  @db.Uuid
  name        String
  description String?
  fileType    String   // "csv", "xlsx", "json", "calculated"
  data        Json?    // { columns: string[], data: any[][] }
  metadata    Json?    // { rowCount, colCount, fileSize, sourceNodeId, etc. }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow    Workflow?  @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workflowId])
  @@map("data_library_file")
}

model SharedNode {
  id              String   @id @default(uuid()) @db.Uuid
  shareKey        String   @unique
  creatorId       String

  expectedColumns Json     // ["col1", "col2", ...]
  data            Json?    // The mapped dataset from the other user

  name            String
  description     String?
  status          String   @default("pending") // "pending", "filled", "consumed"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator         User     @relation("CreatedSharedNodes", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([shareKey])
  @@map("shared_node")
}