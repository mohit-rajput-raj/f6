generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id
  name         String
  email        String
  emailVerified Boolean  @default(false)
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions         Session[]
  accounts         Account[]
  workflows        Workflow[]
  dataLibraryFiles DataLibraryFile[]
  sharedNodes      SharedNode[]     @relation("CreatedSharedNodes")
  publishedWorkflows PublishedWorkflow[] @relation("PublishedWorkflows")
  installedWorkflows WorkflowInstallation[] @relation("InstalledWorkflows")
  masterSheets     MasterSheet[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String   @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id        String   @id
  identifier String
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String
  name        String
  slug        String?  @unique
  description String?

  definition  Json

  isPublic    Boolean  @default(false)
  isTemplate  Boolean  @default(false)
  tags        String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  versions         WorkflowVersion[]
  shares           WorkflowShare[]
  dataLibraryFiles DataLibraryFile[]
  publishedVersions PublishedWorkflow[]
  deskBlocks        DeskBlock[] @relation("ProjectBlocks")
  blockEditor       DeskBlock?  @relation("BlockEditor")

  @@index([userId])
  @@index([isPublic])
  @@index([isTemplate])
  @@map("workflow")
}

model WorkflowVersion {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @db.Uuid
  version    Int
  definition Json
  changeNote String?
  createdAt  DateTime @default(now())

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, version])
  @@unique([workflowId, version])
  @@map("workflow_version")
}

model WorkflowShare {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @db.Uuid
  sharedWith String?  @db.Uuid
  permission String  
  createdAt  DateTime @default(now())

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([sharedWith])
  @@map("workflow_share")
}

model DataLibraryFile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String
  workflowId  String?  @db.Uuid
  name        String
  description String?
  fileType    String   
  data        Json?   
  metadata    Json?  

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow    Workflow?  @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workflowId])
  @@map("data_library_file")
}

model SharedNode {
  id              String   @id @default(uuid()) @db.Uuid
  shareKey        String   @unique
  creatorId       String

  expectedColumns Json     
  data            Json?    

  name            String
  description     String?
  status          String   @default("pending") 

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator         User     @relation("CreatedSharedNodes", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([shareKey])
  @@map("shared_node")
}

model PublishedWorkflow {
  id              String   @id @default(uuid()) @db.Uuid
  workflowId      String   @db.Uuid
  publisherId     String

  name            String
  description     String?
  icon            String?          // emoji or icon name
  version         String   @default("1.0.0")

  // The serialized workflow definition (nodes + edges, minus runtime data)
  definition      Json

  // Schema: what inputs/outputs does this workflow expect?
  inputSchema     Json?    // [{ name, type, description }]
  outputSchema    Json?    // [{ name, type, description }]

  downloads       Int      @default(0)
  isPublic        Boolean  @default(true)
  tags            String[] @default([])
  categories      String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  publisher       User     @relation("PublishedWorkflows", fields: [publisherId], references: [id], onDelete: Cascade)
  workflow        Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  installations   WorkflowInstallation[]

  @@index([publisherId])
  @@index([workflowId])
  @@index([isPublic])
  @@map("published_workflow")
}

model WorkflowInstallation {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String
  publishedWorkflowId String   @db.Uuid

  // User-specific config (e.g., block code mappings)
  config              Json?

  createdAt           DateTime @default(now())

  user                User     @relation("InstalledWorkflows", fields: [userId], references: [id], onDelete: Cascade)
  publishedWorkflow   PublishedWorkflow @relation(fields: [publishedWorkflowId], references: [id], onDelete: Cascade)

  @@unique([userId, publishedWorkflowId])
  @@index([userId])
  @@map("workflow_installation")
}

model MasterSheet {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String
  name        String
  data        Json?    // { columns: string[], data: any[][] }
  metadata    Json?    // { rowCount, colCount, blockCodes, lastMergedAt }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  history     MasterSheetHistory[]
  shares      DeskShare[]

  @@index([userId])
  @@map("master_sheet")
}

model MasterSheetHistory {
  id            String   @id @default(uuid()) @db.Uuid
  masterSheetId String   @db.Uuid
  userId        String
  userName      String
  action        String   // "merge" | "reject" | "update"
  dataBefore    Json?    // snapshot before change
  dataAfter     Json?    // snapshot after change
  changeSummary String?  // "Added 3 columns from CO24553:Th"

  createdAt     DateTime @default(now())

  masterSheet   MasterSheet @relation(fields: [masterSheetId], references: [id], onDelete: Cascade)

  @@index([masterSheetId])
  @@map("master_sheet_history")
}

model DeskShare {
  id                String   @id @default(uuid()) @db.Uuid
  masterSheetId     String   @db.Uuid
  invitedEmail      String
  invitedUserId     String?
  permission        String   @default("editor") // "editor" | "viewer"
  projectWorkflowId String?  @db.Uuid           // link to project for desk-level sharing
  status            String   @default("pending") // "pending" | "accepted" | "rejected"

  createdAt         DateTime @default(now())

  masterSheet   MasterSheet @relation(fields: [masterSheetId], references: [id], onDelete: Cascade)

  @@unique([masterSheetId, invitedEmail])
  @@index([invitedEmail])
  @@index([projectWorkflowId])
  @@map("desk_share")
}

model DeskBlock {
  id                String   @id @default(uuid()) @db.Uuid
  projectWorkflowId String   @db.Uuid
  editorWorkflowId  String   @unique @db.Uuid
  blockOrder        Int      @default(0)

  textInputs        Json?    // [{id, placeholder, value}]
  sheets            Json?    // [{id, name, data: {columns, data}}]
  outputPreview     Json?    // {columns, data}
  checkboxFields    Json?    // [{id, label, checked}]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectWorkflow   Workflow @relation("ProjectBlocks", fields: [projectWorkflowId], references: [id], onDelete: Cascade)
  editorWorkflow    Workflow @relation("BlockEditor", fields: [editorWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
  @@index([blockOrder])
  @@map("desk_block")
}